# entrando na aba "REPORTS"

reports_tab = navegador.find_element(By.ID, "__tab_ctl00_main_tabMain_tabReports")
reports_tab.click()

time.sleep(1)

navegador.get("https://mqs.motorola.com/Collab_GridCpt/default.aspx?enc=Q5gvSdpkrSm4+XI8x/jp2w1wsPbDh0YekbsarrLd0Blcn34hpzKeSNIV4QWOaulvUIlOTwhQ4APoz8Zz4qCb+JXImScVswB7YzdY46WhVHwcsWP2uu4lBUvL6firmhxm")
