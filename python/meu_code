while True:
    try:
        calendario = navegador.find_element(By.ID, "Image1")
        calendario.click()
        time.sleep(1)
        today = navegador.find_element(By.ID,"calendarButtonExtender_today")
        today.click()
        time.sleep(1)
        calendario2 = navegador.find_element(By.ID,"Image2")
        calendario2.click(),time.sleep(1)
